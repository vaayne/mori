    "Connect coding agents to Mori so their status appears in tab names and triggers notifications. Each hook writes a small script to ~/.config/mori/ and registers it with the agent.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c06\u7f16\u7a0b\u4ee3\u7406\u8fde\u63a5\u5230 Mori\uff0c\u4f7f\u5176\u72b6\u6001\u663e\u793a\u5728\u6807\u7b7e\u9875\u540d\u79f0\u4e2d\u5e76\u89e6\u53d1\u901a\u77e5\u3002\u6bcf\u4e2a\u94a9\u5b50\u4f1a\u5728 ~/.config/mori/ \u5199\u5165\u4e00\u4e2a\u5c0f\u811a\u672c\u5e76\u5c06\u5176\u6ce8\u518c\u5230\u4ee3\u7406\u4e2d\u3002"
          }
        }
      }
    },
    "Format: key_combo=action (e.g. super+shift+p=toggle_command_palette)": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u683c\u5f0f\uff1akey_combo=action\uff08\u4f8b\u5982 super+shift+p=toggle_command_palette\uff09"
          }
        }
      }
    },
