    "Treat the macOS Option key as Alt for terminal escape sequences.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\u5c06 macOS Option \u952e\u4f5c\u4e3a Alt \u952e\u7528\u4e8e\u7ec8\u7aef\u8f6c\u4e49\u5e8f\u5217\u3002"
